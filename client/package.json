{
  "name": "client",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "desktop:dev": "node electron/dev.cjs",
    "desktop:export": "node electron/export.cjs",
    "desktop:pack": "node electron/build.cjs --dir",
    "desktop:dist": "node electron/build.cjs --nsis",
    "desktop:pack:mac": "node electron/build.cjs --mac --dir --arm64",
    "desktop:dist:mac": "node electron/build.cjs --mac --dmg --arm64"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.96.0",
    "axios": "^1.14.0",
    "expo": "~54.0.33",
    "expo-constants": "^55.0.9",
    "expo-font": "^55.0.4",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "^55.0.9",
    "expo-router": "^55.0.8",
    "expo-secure-store": "^55.0.9",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "^55.0.11",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.72.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.30.1",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.8.1",
    "tailwindcss": "^3.4.19",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "@types/react-dom": "~19.1.0",
    "babel-preset-expo": "^55.0.13",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "~5.9.2"
  },
  "build": {
    "appId": "pl.ordovita.desktop",
    "productName": "Ordovita",
    "directories": {
      "output": "desktop-dist"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "signAndEditExecutable": false,
      "icon": "assets/icon.png",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "identity": null,
      "hardenedRuntime": false,
      "artifactName": "Ordovita-macOS-${arch}.${ext}"
    },
    "dmg": {
      "title": "Ordovita",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "protocols": [
      {
        "name": "Ordovita OAuth",
        "schemes": [
          "aitaskmanager"
        ]
      }
    ]
  },
  "private": true
}
