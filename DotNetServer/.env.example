# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# Database
# Docker z lokalnym MySQL: Server=host.docker.internal;Port=3306;Database=ordovita;User=root;Password=secret;
# Zdalny hosting: Server=your-host;Database=your-db;User=your-user;Password=your-password;
ConnectionStrings__Database=Server=host.docker.internal;Port=3306;Database=ordovita;User=root;Password=secret;

# Groq LLM
GroqSection__ApiKey=your-groq-api-key
GroqSection__Model=openai/gpt-oss-120b

# SMTP
EmailSection__Host=mail.photodrive.dev
EmailSection__Port=587
EmailSection__Username=kontakt@ordovita.pl
EmailSection__Password=your-smtp-password
EmailSection__FromAddress=kontakt@ordovita.pl
EmailSection__FromName=Ordovita

# Google OAuth
# Alternatywnie: GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET (jak w deploy Java)
Authentication__Google__ClientId=your-google-client-id
Authentication__Google__ClientSecret=your-google-client-secret

# OAuth2 redirect URLs
# Docker dev (frontend :3000): http://localhost:3000
# Lokalny Expo web (:8081):     http://localhost:8081
OAuth2__FrontendUrl=http://localhost:3000
OAuth2__DesktopBrowserCallbackUrl=http://localhost:3000/desktop-oauth-complete
